# === 必填 ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# === AI 摘要（智谱 GLM） ===
ANTHROPIC_AUTH_TOKEN=your_zhipu_api_key
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
AI_MODEL=glm-5

# === 或者用 Anthropic Claude（取消注释，注释掉上面三行） ===
